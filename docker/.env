COMPOSE_PROJECT_NAME=gap-equideg

IMAGE_NAME=ghcr.io/psistwu/gap-docker
GAP_VERSION=4.13.0
IMAGE=${IMAGE_NAME}:${GAP_VERSION}

HOST_PACKAGE_DIR=../
HOST_EXAMPLE_DIR=${HOST_PACKAGE_DIR}/example
HOST_WORKDIR=../workspace

CONTAINER_WORKDIR=/workspace
CONTAINER_GAP_DIR=/opt/gap
CONTAINER_PACKAGE_DIR=${CONTAINER_GAP_DIR}/pkg/equideg
CONTAINER_EXAMPLE_DIR=${CONTAINER_WORKDIR}/example

# Change the token to something else for better security
JUPYTER_TOKEN=mytoken
